rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'y0527148273@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && incoming().role == 'user';
      allow update: if (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])) || isAdmin();
    }

    match /ringtones/{ringtoneId} {
      // 8. Secure List Queries
      allow read: if (resource.data.status == 'published') || isAdmin();
      
      function isValidRingtone(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.artist is string && data.artist.size() <= 200 &&
               data.driveId is string && data.driveId.size() <= 100 &&
               data.status in ['pending', 'published', 'rejected'] &&
               data.createdAt == request.time;
      }

      allow create: if isSignedIn() && isEmailVerified() && isValidRingtone(incoming()) && (
        // Users can only create pending ones
        (incoming().status == 'pending' && incoming().uploadedBy == request.auth.uid) ||
        isAdmin()
      );

      allow update: if (
        isAdmin() || 
        // Action: Increment download count
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['downloadCount']) && incoming().downloadCount == existing().downloadCount + 1)
      );

      allow delete: if isAdmin();
    }
  }
}
